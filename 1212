import React, { useState, useEffect, useMemo } from 'react';
import { initializeApp } from 'firebase/app';
import { getAuth, signInAnonymously, onAuthStateChanged, signInWithCustomToken } from 'firebase/auth';
import { 
  getFirestore, 
  collection, 
  addDoc, 
  onSnapshot, 
  deleteDoc, 
  doc,
  updateDoc,
  serverTimestamp
} from 'firebase/firestore';
import { 
  PieChart, Pie, Cell, ResponsiveContainer, Tooltip, BarChart, Bar, XAxis, YAxis, CartesianGrid, LineChart, Line, AreaChart, Area
} from 'recharts';
import { 
  Upload, FileText, LayoutDashboard, Database, Trash2, CheckCircle, AlertCircle, Loader2, Download, Table, X, ClipboardList, TrendingUp, Edit3, Hash, User, Calendar, ChevronDown, ChevronUp, Package, Clock, Activity, Menu, FileSpreadsheet, Settings, LogOut, Printer, Search, Filter, MoreVertical, Plus
} from 'lucide-react';

// --- Firebase Initialization ---
const firebaseConfig = JSON.parse(__firebase_config);
const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);
const appId = typeof __app_id !== 'undefined' ? __app_id : 'doc-scanner-modiin';

const STATUS_OPTIONS = ['בעבודה', 'טופל חלקית', 'הושלם', 'מבוטל'];
const GOOGLE_COLORS = {
  blue: '#1a73e8',
  red: '#ea4335',
  yellow: '#fbbc04',
  green: '#34a853',
  gray: '#5f6368',
  lightGray: '#f8f9fa',
  border: '#dadce0'
};

// --- רכיב שעון (Gauge) אלגנטי ---
const StatusGauge = ({ value, total, label, color, icon: Icon }) => {
  const data = [{ value: value }, { value: Math.max(0, total - value) }];
  return (
    <div className="bg-white p-6 rounded-[24px] border border-[#dadce0] flex flex-col items-center justify-center relative hover:shadow-md transition-all duration-300 group">
      <div className="absolute top-4 left-4 text-slate-100 group-hover:text-slate-200 transition-colors">
        <Icon size={32} />
      </div>
      <div className="w-full h-36">
        <ResponsiveContainer width="100%" height="100%">
          <PieChart>
            <Pie data={data} cx="50%" cy="100%" startAngle={180} endAngle={0} innerRadius="80%" outerRadius="100%" paddingAngle={0} dataKey="value" stroke="none">
              <Cell fill={color} />
              <Cell fill="#f1f3f4" />
            </Pie>
          </PieChart>
        </ResponsiveContainer>
      </div>
      <div className="mt-[-25px] flex flex-col items-center z-10">
        <span className="text-4xl font-google text-slate-900 font-bold">{value}</span>
        <span className="text-[11px] font-bold text-slate-500 uppercase tracking-widest mt-1">{label}</span>
      </div>
    </div>
  );
};

export default function App() {
  const [user, setUser] = useState(null);
  const [activeTab, setActiveTab] = useState('dashboard');
  const [records, setRecords] = useState([]);
  const [isScanning, setIsScanning] = useState(false);
  const [error, setError] = useState(null);
  const [successMsg, setSuccessMsg] = useState(null);
  const [pendingData, setPendingData] = useState(null); 
  const [expandedRow, setExpandedRow] = useState(null);
  const [isSidebarOpen, setIsSidebarOpen] = useState(false);
  const [searchQuery, setSearchQuery] = useState("");

  useEffect(() => {
    const initAuth = async () => {
      try {
        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
          await signInWithCustomToken(auth, __initial_auth_token);
        } else {
          await signInAnonymously(auth);
        }
      } catch (err) { setError("שגיאה בחיבור למערכת."); }
    };
    initAuth();
    return onAuthStateChanged(auth, setUser);
  }, []);

  useEffect(() => {
    if (!user) return;
    const q = collection(db, 'artifacts', appId, 'public', 'data', 'orders');
    const unsubscribe = onSnapshot(q, (snapshot) => {
      const data = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
      setRecords(data.sort((a, b) => new Date(b.date) - new Date(a.date)));
    }, () => setError("שגיאה בסנכרון הנתונים."));
    return () => unsubscribe();
  }, [user]);

  const analyzeContent = async (content) => {
    // השתמש במפתח ה-API של Gemini שהזנת
    const apiKey = "AIzaSyAHhNGhAynvDl_WhjB6_BMZSini96_bMlw"; 
    
    const prompt = `Analyze this Hebrew order/quote. Extract general info and ALL items. Return ONLY JSON: {"vendor": "Name", "orderNumber": "123", "client": "Name", "date": "YYYY-MM-DD", "items": [{"description": "Item", "quantity": 1, "unitPrice": 10, "total": 10}]}`;
    const body = { contents: [{ parts: [{ text: prompt }, { inlineData: { mimeType: content.mimeType, data: content.data.split(',')[1] } }] }] };
    const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
    const result = await response.json();
    const text = result.candidates?.[0]?.content?.parts?.[0]?.text || "";
    const jsonMatch = text.match(/\{[\s\S]*\}/);
    if (!jsonMatch) throw new Error("AI parsing error");
    const parsed = JSON.parse(jsonMatch[0]);
    parsed.status = 'בעבודה';
    parsed.items = parsed.items.map(item => ({ ...item, status: 'בעבודה' }));
    return parsed;
  };

  const handleFileUpload = async (e) => {
    const file = e.target.files[0];
    if (!file || !user) return;
    setIsScanning(true);
    setError(null);
    const reader = new FileReader();
    reader.onload = async (event) => {
      try {
        const data = await analyzeContent({ data: event.target.result, mimeType: file.type });
        setPendingData(data);
      } catch (err) { setError("נכשל בניתוח הקובץ."); }
      finally { setIsScanning(false); }
    };
    reader.readAsDataURL(file);
  };

  const saveOrder = async () => {
    if (!user || !pendingData) return;
    try {
      const totalAmount = pendingData.items.reduce((s, i) => s + (Number(i.total) || 0), 0);
      await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'orders'), {
        ...pendingData,
        totalAmount,
        createdAt: new Date().toISOString(),
        userId: user.uid
      });
      setPendingData(null);
      setSuccessMsg("הזמנה נשמרה בסטטוס בעבודה");
      setActiveTab('records');
      setTimeout(() => setSuccessMsg(null), 3000);
    } catch (err) { setError("שגיאה בשמירה."); }
  };

  const createEmptyOrder = () => {
    setPendingData({
      vendor: "דפוס מודיעין",
      orderNumber: "",
      client: "",
      date: new Date().toISOString().split('T')[0],
      status: "בעבודה",
      items: [{ description: "", quantity: 1, unitPrice: 0, total: 0, status: "בעבודה" }]
    });
  };

  const updateItemStatus = async (orderId, itemIndex, newStatus) => {
    try {
      const order = records.find(r => r.id === orderId);
      if (!order) return;
      const newItems = [...order.items];
      newItems[itemIndex].status = newStatus;
      const allCompleted = newItems.every(item => item.status === 'הושלם');
      const anyActionTaken = newItems.some(item => item.status !== 'בעבודה');
      let newOverallStatus = 'בעבודה';
      if (allCompleted) newOverallStatus = 'הושלם';
      else if (anyActionTaken) newOverallStatus = 'טופל חלקית';
      await updateDoc(doc(db, 'artifacts', appId, 'public', 'data', 'orders', orderId), { items: newItems, status: newOverallStatus });
    } catch (err) { setError("שגיאה בעדכון."); }
  };

  const exportToSheets = () => {
    const headers = ["Order_ID", "Order_Number", "Date", "Client", "Vendor", "Item_Description", "Quantity", "Price", "Total", "Item_Status", "Overall_Status"];
    const rows = [];
    records.forEach(order => order.items.forEach(item => rows.push([order.id, order.orderNumber, order.date, order.client, order.vendor, item.description, item.quantity, item.unitPrice, item.total, item.status, order.status])));
    let csvContent = "\uFEFF" + headers.join(",") + "\n" + rows.map(r => r.map(v => `"${String(v).replace(/"/g, '""')}"`).join(",")).join("\n");
    const link = document.createElement("a");
    link.href = URL.createObjectURL(new Blob([csvContent], { type: 'text/csv;charset=utf-8;' }));
    link.download = `Modiin_Sync_${new Date().getTime()}.csv`;
    link.click();
  };

  const filteredRecords = useMemo(() => records.filter(r => r.client?.toLowerCase().includes(searchQuery.toLowerCase()) || r.orderNumber?.toString().includes(searchQuery)), [records, searchQuery]);
  const totalRevenue = records.reduce((s, r) => s + (Number(r.totalAmount) || 0), 0);
  const counts = { inWork: records.filter(r => r.status === 'בעבודה').length, partial: records.filter(r => r.status === 'טופל חלקית').length, completed: records.filter(r => r.status === 'הושלם').length };

  return (
    <div className="min-h-screen bg-white text-slate-900 font-sans flex flex-col md:flex-row-reverse" dir="rtl">
      
      {/* Sidebar - Google Workspace Style */}
      <aside className={`fixed inset-y-0 right-0 z-50 w-72 bg-white border-l border-[#dadce0] transition-transform duration-300 md:translate-x-0 md:static ${isSidebarOpen ? 'translate-x-0' : 'translate-x-full'}`}>
        <div className="flex flex-col h-full px-4 py-8">
          <div className="flex items-center gap-3 mb-10 px-4">
            <div className="bg-blue-600 p-2 rounded-xl text-white"><Printer size={24} /></div>
            <div className="overflow-hidden">
              <h1 className="text-lg font-bold text-slate-800 leading-tight">דפוס מודיעין</h1>
              <span className="text-[10px] text-slate-400 font-medium uppercase tracking-wider">מעקב הזמנות</span>
            </div>
          </div>

          <nav className="space-y-1 flex-1">
            <button onClick={() => { setActiveTab('dashboard'); setIsSidebarOpen(false); }} className={`w-full flex items-center gap-4 px-4 py-3 rounded-full font-medium transition-all ${activeTab === 'dashboard' ? 'bg-blue-50 text-blue-700' : 'text-slate-600 hover:bg-slate-50'}`}><LayoutDashboard size={20} /><span className="text-sm">דשבורד</span></button>
            <button onClick={() => { setActiveTab('records'); setIsSidebarOpen(false); }} className={`w-full flex items-center gap-4 px-4 py-3 rounded-full font-medium transition-all ${activeTab === 'records' ? 'bg-blue-50 text-blue-700' : 'text-slate-600 hover:bg-slate-50'}`}><Database size={20} /><span className="text-sm">הזמנות</span></button>
            <div className="pt-4 mt-4 border-t border-slate-100">
              <button onClick={exportToSheets} className="w-full flex items-center gap-4 px-4 py-3 rounded-full font-medium text-slate-600 hover:bg-emerald-50 hover:text-emerald-700 transition-colors"><FileSpreadsheet size={20} className="text-green-600" /><span className="text-sm">ייצוא ל-Sheets</span></button>
            </div>
          </nav>

          <div className="mt-auto pt-6 border-t border-slate-100 px-4 flex items-center gap-3">
            <div className="w-10 h-10 rounded-full bg-[#e8f0fe] flex items-center justify-center text-blue-700 font-bold border border-blue-100">צ</div>
            <div className="flex-1 overflow-hidden"><p className="text-sm font-bold text-slate-800 truncate">צחי שרביט</p><p className="text-[10px] text-slate-400">מנהל מערכת</p></div>
          </div>
        </div>
      </aside>

      <div className="flex-1 flex flex-col h-screen overflow-hidden bg-[#f8f9fa]">
        
        {/* Header Bar */}
        <header className="h-16 md:h-20 bg-white/70 backdrop-blur-md flex items-center justify-between px-6 md:px-10 sticky top-0 z-30 border-b border-[#dadce0]">
          <div className="flex items-center gap-4 flex-1">
            <button onClick={() => setIsSidebarOpen(true)} className="md:hidden p-2 text-slate-600"><Menu size={24} /></button>
            <div className="max-w-md w-full relative hidden sm:block">
              <Search className="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400" size={18} />
              <input type="text" placeholder="חיפוש לפי לקוח או הזמנה..." className="w-full bg-[#f1f3f4] border-none rounded-full py-2.5 pr-12 pl-4 text-sm focus:bg-white focus:ring-2 ring-blue-100 transition-all outline-none" value={searchQuery} onChange={(e) => setSearchQuery(e.target.value)} />
            </div>
          </div>

          <div className="flex items-center gap-3">
             <button onClick={createEmptyOrder} className="hidden sm:flex items-center gap-2 px-6 py-2.5 bg-white border border-[#dadce0] text-blue-600 rounded-full font-bold hover:bg-blue-50 transition-all text-sm">
                <Plus size={18} />
                <span>הוספה ידנית</span>
             </button>
             <label className="flex items-center gap-2 px-6 py-2.5 bg-blue-600 text-white rounded-full font-bold shadow-lg hover:bg-blue-700 cursor-pointer transition-all text-sm">
                {isScanning ? <Loader2 className="animate-spin" size={18} /> : <Upload size={18} />}
                <span>סרוק PDF</span>
                <input type="file" accept="application/pdf,image/*" className="hidden" onChange={handleFileUpload} disabled={isScanning} />
             </label>
          </div>
        </header>

        {/* Content Area */}
        <main className="flex-1 overflow-y-auto p-6 md:p-10">
          {successMsg && (
            <div className="fixed top-24 left-1/2 -translate-x-1/2 z-[100] animate-in slide-in-from-top duration-300">
              <div className="bg-slate-900 text-white px-8 py-3 rounded-full shadow-2xl flex items-center gap-3"><CheckCircle size={18} className="text-green-400" /><span className="text-sm font-medium">{successMsg}</span></div>
            </div>
          )}

          {/* Modal המכיל את כפתור ה"שמור" - מופיע בסיטואציית סריקה או הוספה ידנית */}
          {pendingData && (
            <div className="fixed inset-0 bg-slate-900/40 z-[60] flex items-center justify-center p-4 backdrop-blur-sm">
              <div className="bg-white rounded-[28px] w-full max-w-4xl shadow-2xl p-8 animate-in zoom-in duration-200 border border-[#dadce0]">
                <div className="flex justify-between items-center mb-8">
                  <h2 className="text-2xl font-bold text-slate-800">פרטי הזמנה חדשה</h2>
                  <button onClick={() => setPendingData(null)} className="p-2 hover:bg-slate-100 rounded-full transition-colors"><X /></button>
                </div>
                
                <div className="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8 p-6 bg-[#f8f9fa] rounded-2xl border border-[#dadce0]">
                  <div><label className="text-[11px] font-bold text-slate-400 uppercase mb-1 block tracking-wider">לקוח</label><input className="w-full bg-white border border-[#dadce0] rounded-lg p-2 font-bold" value={pendingData.client} onChange={e => setPendingData({...pendingData, client: e.target.value})} /></div>
                  <div><label className="text-[11px] font-bold text-slate-400 uppercase mb-1 block tracking-wider">מספר הזמנה</label><input className="w-full bg-white border border-[#dadce0] rounded-lg p-2 font-bold" value={pendingData.orderNumber} onChange={e => setPendingData({...pendingData, orderNumber: e.target.value})} /></div>
                  <div><label className="text-[11px] font-bold text-slate-400 uppercase mb-1 block tracking-wider">תאריך</label><input type="date" className="w-full bg-white border border-[#dadce0] rounded-lg p-2 font-bold" value={pendingData.date} onChange={e => setPendingData({...pendingData, date: e.target.value})} /></div>
                </div>

                <div className="max-h-[300px] overflow-y-auto space-y-3 mb-8 pr-2 custom-scrollbar">
                  {pendingData.items.map((item, idx) => (
                    <div key={idx} className="flex flex-col md:flex-row gap-3 p-4 bg-white border border-[#dadce0] rounded-xl relative group">
                      <div className="flex-1"><input placeholder="תיאור פריט" className="w-full bg-slate-50 border-none p-2 rounded-lg text-sm" value={item.description} onChange={e => { const items = [...pendingData.items]; items[idx].description = e.target.value; setPendingData({...pendingData, items}); }} /></div>
                      <div className="w-20"><input type="number" placeholder="כמות" className="w-full bg-slate-50 border-none p-2 rounded-lg text-sm text-center" value={item.quantity} onChange={e => { const items = [...pendingData.items]; items[idx].quantity = e.target.value; items[idx].total = Number(e.target.value) * Number(items[idx].unitPrice); setPendingData({...pendingData, items}); }} /></div>
                      <div className="w-24"><input type="number" placeholder="מחיר" className="w-full bg-slate-50 border-none p-2 rounded-lg text-sm text-center" value={item.unitPrice} onChange={e => { const items = [...pendingData.items]; items[idx].unitPrice = e.target.value; items[idx].total = Number(e.target.value) * Number(items[idx].quantity); setPendingData({...pendingData, items}); }} /></div>
                      <div className="w-28 font-bold text-blue-600 flex items-center justify-center bg-blue-50 rounded-lg">₪{item.total}</div>
                      <button onClick={() => { const items = pendingData.items.filter((_, i) => i !== idx); setPendingData({...pendingData, items}); }} className="p-1 text-slate-300 hover:text-red-500"><Trash2 size={16}/></button>
                    </div>
                  ))}
                  <button onClick={() => setPendingData({...pendingData, items: [...pendingData.items, {description: "", quantity: 1, unitPrice: 0, total: 0, status: "בעבודה"}]})} className="flex items-center gap-2 text-blue-600 font-bold text-xs p-2 hover:bg-blue-50 rounded-lg transition-colors"><Plus size={14}/> הוסף שורה</button>
                </div>

                <div className="flex justify-between items-center border-t border-slate-100 pt-8">
                  <div><p className="text-xs text-slate-400 font-bold mb-1 uppercase tracking-widest">סה"כ לתשלום</p><h3 className="text-3xl font-bold text-slate-900">₪{pendingData.items.reduce((s, i) => s + (Number(i.total) || 0), 0).toLocaleString()}</h3></div>
                  <div className="flex gap-4">
                    <button onClick={() => setPendingData(null)} className="px-8 py-4 text-slate-500 font-bold hover:bg-slate-50 rounded-full transition-all">ביטול</button>
                    <button onClick={saveOrder} className="px-12 py-4 bg-blue-600 text-white rounded-full font-bold text-lg hover:bg-blue-700 shadow-xl shadow-blue-100 transition-all active:scale-95">שמור הזמנה</button>
                  </div>
                </div>
              </div>
            </div>
          )}

          {activeTab === 'dashboard' ? (
            <div className="space-y-10 animate-in fade-in duration-700 max-w-7xl mx-auto">
              <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                 <StatusGauge value={counts.inWork} total={records.length} label="הזמנות בעבודה" color={GOOGLE_COLORS.blue} icon={Clock} />
                 <StatusGauge value={counts.partial} total={records.length} label="טופלו חלקית" color={GOOGLE_COLORS.yellow} icon={Activity} />
                 <StatusGauge value={counts.completed} total={records.length} label="הושלמו" color={GOOGLE_COLORS.green} icon={CheckCircle} />
                 <div className="bg-white p-8 rounded-[24px] border border-[#dadce0] flex flex-col justify-center relative overflow-hidden">
                    <p className="text-[11px] font-bold text-slate-400 uppercase mb-2 relative z-10">מחזור הכנסות</p>
                    <h3 className="text-3xl font-bold text-slate-900 tracking-tight relative z-10">₪{totalRevenue.toLocaleString()}</h3>
                    <div className="mt-4 flex items-center gap-2 text-blue-600 text-[11px] font-bold bg-blue-50 w-fit px-3 py-1 rounded-full relative z-10">{records.length} הזמנות</div>
                 </div>
              </div>
              <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <div className="bg-white p-8 rounded-[28px] border border-[#dadce0] h-[400px]"><h4 className="text-slate-800 font-bold text-sm mb-10 flex items-center gap-2"><Package size={18} className="text-blue-600"/> פילוח לפי ספקים (₪)</h4><ResponsiveContainer width="100%" height="100%"><BarChart data={Object.entries(records.reduce((acc, r) => {acc[r.vendor]=(acc[r.vendor]||0)+r.totalAmount; return acc;}, {})).map(([name, value]) => ({name, value}))}><XAxis dataKey="name" axisLine={false} tickLine={false} tick={{fontSize:10, fill:'#94a3b8', fontWeight: 'bold'}} /><YAxis axisLine={false} tickLine={false} tick={{fontSize:10, fill:'#94a3b8'}} /><Tooltip cursor={{fill: '#f8f9fa', radius: 10}} contentStyle={{borderRadius: '16px', border: 'none', boxShadow: '0 10px 25px rgba(0,0,0,0.05)'}} /><Bar dataKey="value" fill={GOOGLE_COLORS.blue} radius={[8, 8, 0, 0]} barSize={45} /></BarChart></ResponsiveContainer></div>
                <div className="bg-white p-8 rounded-[28px] border border-[#dadce0] h-[400px]"><h4 className="text-slate-800 font-bold text-sm mb-10 flex items-center gap-2"><TrendingUp size={18} className="text-green-600"/> מגמת הכנסות</h4><ResponsiveContainer width="100%" height="100%"><AreaChart data={records.slice(0, 12).reverse()}><defs><linearGradient id="colorRev" x1="0" y1="0" x2="0" y2="1"><stop offset="5%" stopColor={GOOGLE_COLORS.green} stopOpacity={0.1}/><stop offset="95%" stopColor={GOOGLE_COLORS.green} stopOpacity={0}/></linearGradient></defs><CartesianGrid strokeDasharray="3 3" vertical={false} stroke="#f1f5f9" /><XAxis dataKey="date" hide /><YAxis axisLine={false} tickLine={false} tick={{fontSize:10, fill:'#94a3b8'}} /><Tooltip contentStyle={{borderRadius: '16px', border: 'none', boxShadow: '0 10px 25px rgba(0,0,0,0.05)'}} /><Area type="monotone" dataKey="totalAmount" stroke={GOOGLE_COLORS.green} strokeWidth={4} fillOpacity={1} fill="url(#colorRev)" dot={{r:5, fill: GOOGLE_COLORS.green, strokeWidth: 2, stroke: '#fff'}} /></AreaChart></ResponsiveContainer></div>
              </div>
            </div>
          ) : (
            <div className="max-w-7xl mx-auto animate-in fade-in duration-500">
              <div className="bg-white rounded-[28px] border border-[#dadce0] shadow-sm overflow-hidden">
                <table className="w-full text-right min-w-[900px]">
                  <thead><tr className="bg-[#f8f9fa] border-b border-[#dadce0] text-[11px] font-bold text-slate-500 uppercase tracking-wider"><th className="px-8 py-5">מס' הזמנה</th><th className="px-8 py-5">לקוח</th><th className="px-8 py-5 text-center">תאריך</th><th className="px-8 py-5 text-center">סטטוס כללי</th><th className="px-8 py-5 text-left">סה"כ</th><th className="px-8 py-5"></th></tr></thead>
                  <tbody className="divide-y divide-slate-100">
                    {filteredRecords.map((order) => (
                      <React.Fragment key={order.id}>
                        <tr onClick={() => setExpandedRow(expandedRow === order.id ? null : order.id)} className={`hover:bg-blue-50/20 transition-all cursor-pointer group ${expandedRow === order.id ? 'bg-blue-50/40' : ''}`}><td className="px-8 py-6 font-bold text-blue-600"><div className="flex items-center gap-3"><div className={`p-1.5 rounded-lg transition-colors ${expandedRow === order.id ? 'bg-blue-600 text-white' : 'bg-blue-50 text-blue-600'}`}>{expandedRow === order.id ? <ChevronUp size={14}/> : <ChevronDown size={14}/>}</div>#{order.orderNumber}</div></td><td className="px-8 py-6 font-bold text-slate-800">{order.client}</td><td className="px-8 py-6 text-slate-500 text-sm font-medium text-center">{order.date}</td><td className="px-8 py-6 text-center"><span className={`px-4 py-1.5 rounded-full text-[10px] font-bold uppercase inline-flex items-center gap-2 ${order.status === 'בעבודה' ? 'bg-blue-100 text-blue-700' : order.status === 'טופל חלקית' ? 'bg-amber-100 text-amber-700' : order.status === 'הושלם' ? 'bg-green-100 text-green-700' : 'bg-slate-100 text-slate-700'}`}><span className={`w-1.5 h-1.5 rounded-full ${order.status === 'בעבודה' ? 'bg-blue-500' : order.status === 'טופל חלקית' ? 'bg-amber-500' : 'bg-green-500'}`}></span>{order.status || 'בעבודה'}</span></td><td className="px-8 py-6 font-black text-slate-900 text-left">₪{order.totalAmount?.toLocaleString()}</td><td className="px-8 py-6 text-center"><button onClick={(e) => { e.stopPropagation(); if(window.confirm('למחוק לצמיתות?')) deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', 'orders', order.id)); }} className="text-slate-300 hover:text-red-500 p-2 opacity-0 group-hover:opacity-100 transition-all"><Trash2 size={18}/></button></td></tr>
                        {expandedRow === order.id && (
                          <tr className="bg-blue-50/10"><td colSpan="6" className="px-12 py-10 animate-in slide-in-from-top-4 duration-300"><div className="bg-white rounded-[24px] border border-[#dadce0] overflow-hidden shadow-xl"><table className="w-full text-right text-xs"><thead className="bg-[#1a73e8] text-white font-bold"><tr><th className="px-6 py-4">פירוט פריט</th><th className="px-6 py-4 text-center">כמות</th><th className="px-6 py-4 text-center">מחיר יח'</th><th className="px-6 py-4 text-center">סטטוס שורה</th><th className="px-6 py-4 text-left">סה"כ</th></tr></thead><tbody className="divide-y divide-[#dadce0]">{order.items?.map((item, i) => (<tr key={i} className="hover:bg-slate-50 transition-colors"><td className="px-6 py-4 font-medium text-slate-700">{item.description}</td><td className="px-6 py-4 text-center text-slate-500 font-bold">{item.quantity}</td><td className="px-6 py-4 text-center text-slate-500 font-medium">₪{item.unitPrice?.toLocaleString()}</td><td className="px-6 py-4 text-center"><select value={item.status || 'בעבודה'} onChange={(e) => updateItemStatus(order.id, i, e.target.value)} className={`border border-[#dadce0] text-[10px] font-bold p-2 rounded-lg outline-none cursor-pointer transition-all ${item.status === 'בעבודה' ? 'bg-white text-blue-700' : item.status === 'הושלם' ? 'bg-green-50 text-green-700' : 'bg-amber-50 text-amber-700'}`}>{STATUS_OPTIONS.map(opt => <option key={opt} value={opt}>{opt}</option>)}</select></td><td className="px-6 py-4 text-left font-bold text-blue-600">₪{item.total?.toLocaleString()}</td></tr>))}</tbody></table></div></td></tr>
                        )}
                      </React.Fragment>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          )}
        </main>
      </div>

      {/* FAB - Google Signature Button */}
      <button 
        onClick={createEmptyOrder}
        className="fixed bottom-8 left-8 w-14 h-14 bg-white text-blue-600 rounded-[16px] shadow-2xl flex items-center justify-center hover:bg-blue-50 transition-all z-[100] border border-[#dadce0] md:hidden"
      >
        <Plus size={28} />
      </button>

    </div>
  );
}
